# Project environment variables (template)
#
# Copy this file to `.env` and fill in actual values:
#     cp .env.example .env       # macOS / Linux
#     Copy-Item .env.example .env  # PowerShell
#
# `.env` itself is gitignored — never commit it.
# Sections are organized by feature area; uncomment / add as needed.

# === Application ===
# APP_VAR_1=replace_me

# === Authentication (if applicable) ===
# AUTH_USERNAME=replace_me
# AUTH_PASSWORD=replace_me_with_strong_value_16_chars_or_more

# === External services (if applicable) ===
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# API_KEY=replace_me
